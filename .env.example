# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Leads source — path to a CSV with columns: name, email, company, notes (optional)
LEADS_FILE=leads.csv

# Output file for qualified leads report (production mode)
OUTPUT_FILE=qualified_leads.json

# Obsidian vault path (optional — agent will check common locations if not set)
OBSIDIAN_VAULT_PATH=./vault
